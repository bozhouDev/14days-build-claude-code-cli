          "body": "name='system_date'",
          "detail": "模型返回的是 assistant content block：type='tool_use'、id、name、input。harness 必须先把这整条 assistant message append 回 messages。",
          "position": { "x": 600, "y": 70 },
          "mobilePosition": { "x": 0, "y": 210 }
        },
        {
          "id": "run-tool",
          "kind": "tool",
          "label": "ToolRegistry.run",
          "eyebrow": "harness",
          "body": "system_date({})",
