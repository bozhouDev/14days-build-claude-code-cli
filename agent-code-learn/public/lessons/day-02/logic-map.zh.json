          "position": { "x": 900, "y": 70 },
          "mobilePosition": { "x": 280, "y": 210 }
        },
        {
          "id": "user-tool-result",
          "kind": "data",
          "label": "user message",
          "eyebrow": "type='tool_result'",
          "body": "tool_use_id + content",
          "detail": "这是 Day 2 的关键协议点：tool_result 放在下一轮 role='user' 的 content block 里，并用 tool_use_id 对上上一条 tool_use id；不是 Day 1 的 role='tool'。",
          "position": { "x": 900, "y": 320 },
          "mobilePosition": { "x": 280, "y": 420 }
        },
        {
          "id": "final-response",
          "kind": "response",
          "label": "ModelResponse",
