        {
          "id": "tools-result",
          "source": "local-tools",
          "target": "tool-result",
          "label": "observe",
          "sourceHandle": "source-bottom",
          "targetHandle": "target-top"
        },
        {
          "id": "result-messages",
          "source": "tool-result",
          "target": "messages",
          "sourceHandle": "source-top",
          "targetHandle": "target-bottom"
        },
        {
          "id": "provider-stdout",
          "source": "provider",
          "target": "stdout",
          "sourceHandle": "source-bottom",
          "targetHandle": "target-top"
        }
      ]
    },
    {
      "id": "fs-safety",
      "label": "fs_safety gate",
      "title": "read_file 的 fs_safety 安全门",
      "summary": "read_file 不直接读盘，而是先经过 cwd 锁定、文本判断、大小上限、ReadFileState 记录和输出截断。",
      "defaultActiveNodeId": "resolve",
      "nodes": [
        {
          "id": "read-file",
          "kind": "tool",
          "label": "read_file",
          "eyebrow": "tool",
          "body": "path from model",
          "detail": "模型只提供相对路径，例如 pyproject.toml。这个参数不能直接交给 Path.read_text。",
          "position": { "x": 0, "y": 80 },
          "mobilePosition": { "x": 0, "y": 0 }
        },
        {
          "id": "resolve",
          "kind": "data",
          "label": "resolve_in_cwd",
          "eyebrow": "gate 1",
          "body": "lock path inside cwd",
          "detail": "resolve_in_cwd 把模型给的路径解析成绝对路径，再用 relative_to(cwd) 证明它没有逃出 cwd。",
          "position": { "x": 270, "y": 80 },
          "mobilePosition": { "x": 280, "y": 0 }
        },
        {
          "id": "text",
          "kind": "data",
          "label": "ensure_text_file",
          "eyebrow": "gate 2",
          "body": "reject binary",
          "detail": "白名单后缀直接放行；其他文件 peek 前 1 KiB，看到 NUL 字节就作为二进制拒绝。",
          "position": { "x": 540, "y": 80 },
          "mobilePosition": { "x": 0, "y": 210 }
        },
        {
          "id": "size",
          "kind": "data",
          "label": "ensure_within_size",
          "eyebrow": "gate 3",
          "body": "256 KiB cap",
          "detail": "单文件超过 256 KiB 就拒绝整文件读取，引导模型改用 grep 或后续 offset/limit 版本。",
          "position": { "x": 810, "y": 80 },
          "mobilePosition": { "x": 280, "y": 210 }
        },
        {
          "id": "read-text",
          "kind": "tool",
          "label": "Path.read_text",
          "eyebrow": "world",
          "body": "read disk",
          "detail": "只有三道 gate 都通过，harness 才真正读取磁盘内容。",
          "position": { "x": 810, "y": 340 },
          "mobilePosition": { "x": 0, "y": 420 }
        },
        {
          "id": "record",
          "kind": "data",
          "label": "ReadFileState",
          "eyebrow": "state",
          "body": "record(mtime, chars)",
          "detail": "Day 3 只记录，不读取。Day 4 的 read-before-edit 会用这份状态判断文件是否在读取后又被改过。",
          "position": { "x": 540, "y": 340 },
          "mobilePosition": { "x": 280, "y": 420 }
        },
        {
          "id": "truncate",
          "kind": "data",
          "label": "truncate_output",
          "eyebrow": "context",
          "body": "max 8000 chars",
          "detail": "工具 observation 进入模型上下文前会被截断，防止单次工具结果把上下文撑爆。",
          "position": { "x": 270, "y": 340 },
          "mobilePosition": { "x": 0, "y": 630 }
        },
        {
          "id": "result",
          "kind": "response",
          "label": "ToolResult",
          "eyebrow": "observation",
          "body": "text or error",
          "detail": "成功和失败都会变成 ToolResult。未知文件、越界、二进制、大文件都不会让 Agent Loop 崩掉。",
          "position": { "x": 0, "y": 340 },
          "mobilePosition": { "x": 280, "y": 630 }
        }
      ],
