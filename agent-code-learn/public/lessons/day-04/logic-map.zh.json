          "position": { "x": 900, "y": 320 },
          "mobilePosition": { "x": 0, "y": 420 }
        },
        {
          "id": "diff",
          "kind": "output",
          "label": "render_diff",
          "eyebrow": "human review",
          "body": "unified diff preview",
          "detail": "diff 是展示给人的，不进入 messages。模型只会看到最终的 ToolResult observation。",
          "position": { "x": 600, "y": 320 },
          "mobilePosition": { "x": 280, "y": 420 }
        },
        {
          "id": "confirm",
          "kind": "runtime",
          "label": "typer.confirm",
          "eyebrow": "y/N",
          "body": "user accepts or rejects",
          "detail": "默认 N。用户按 n 会产生 error: edit rejected by user；用户按 y 才进入真正的工具执行。",
