          "position": { "x": 300, "y": 80 },
          "mobilePosition": { "x": 280, "y": 0 }
        },
        {
          "id": "path",
          "kind": "data",
          "label": "resolve_in_cwd",
          "eyebrow": "gate 1",
          "body": "lock path inside cwd",
          "detail": "写工具和读工具一样，先把模型给的相对路径解析进 cwd；逃出 cwd 直接变成 error ToolResult。",
          "position": { "x": 600, "y": 80 },
          "mobilePosition": { "x": 0, "y": 210 }
        },
        {
          "id": "read-state",
          "kind": "data",
          "label": "read-before-edit",
          "eyebrow": "gate 2",
          "body": "ensure + mtime check",
          "detail": "已有文件的 file_write 和所有 file_edit 都必须先读过；读完后 mtime 变了也会被 check_mtime_conflict 拦住。",
          "position": { "x": 900, "y": 80 },
          "mobilePosition": { "x": 280, "y": 210 }
        },
        {
          "id": "replace",
          "kind": "data",
          "label": "apply_single_replace",
          "eyebrow": "file_edit",
          "body": "dry-run replacement",
