        {
          "id": "tool-use",
          "kind": "response",
          "label": "tool_use",
          "eyebrow": "model",
          "body": "file_write / file_edit",
          "detail": "模型只表达编辑意图：要写哪个 file_path、content 或 old_string/new_string。它不能直接改磁盘文件。",
          "position": { "x": 0, "y": 80 },
          "mobilePosition": { "x": 0, "y": 0 }
        },
        {
          "id": "intercept",
          "kind": "tool",
          "label": "agent.py intercept block",
          "eyebrow": "harness",
          "body": "pre-checks before tools.run",
