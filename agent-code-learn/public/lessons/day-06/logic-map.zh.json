          "mobilePosition": { "x": 0, "y": 320 }
        },
        {
          "id": "builder",
          "kind": "runtime",
          "label": "build_system_prompt",
          "eyebrow": "harness",
          "body": "core → AGENT.md → MEMORY.md",
          "detail": "这个函数在 CLI cold start 调一次。三层都可选，文件不存在就跳过；拼好的文本通过 system= 传给 Provider。",
          "position": { "x": 380, "y": 180 },
          "mobilePosition": { "x": 220, "y": 160 }
        },
        {
          "id": "provider",
          "kind": "model",
          "label": "Provider.complete",
          "eyebrow": "system=",
          "body": "messages + system",
          "detail": "AnthropicProvider 把 system prompt 放在请求顶层，和 messages 平级。它不是 messages 的第一条消息。",
          "position": { "x": 760, "y": 180 },
          "mobilePosition": { "x": 0, "y": 500 }
        },
        {
          "id": "compact",
          "kind": "runtime",
          "label": "compact(messages)",
          "eyebrow": "not system",
          "body": "pinned + summary + working",
          "detail": "compact 只压 messages。AGENT.md 和 MEMORY.md 走 system= 旁路，因此不会被压缩丢掉。",
          "position": { "x": 760, "y": 360 },
          "mobilePosition": { "x": 220, "y": 500 }
        }
      ],
      "edges": [
        { "id": "core-builder", "source": "core", "target": "builder", "label": "part 1" },
        { "id": "agent-builder", "source": "agent-md", "target": "builder", "label": "optional" },
        { "id": "memory-builder", "source": "memory-index", "target": "builder", "label": "optional" },
        { "id": "builder-provider", "source": "builder", "target": "provider", "label": "system=" },
