        {
          "id": "agent-md",
          "kind": "data",
          "label": "AGENT.md",
          "eyebrow": "project rules",
          "body": "<project-rules>",
          "detail": "项目规则由开发者手写，启动时读取 cwd 下的 AGENT.md，并包进 <project-rules> 块。",
