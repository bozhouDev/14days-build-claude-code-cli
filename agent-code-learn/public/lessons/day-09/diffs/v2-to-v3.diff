--- agent_code/tools.py
+++ agent_code/tools.py
@@ ToolRegistry.get 后面
+    def filtered(self, allowed_names: list[str] | None) -> "ToolRegistry":
+        """给模型看的工具面。None 表示不收敛，[] 表示不给任何工具。"""
+        if allowed_names is None:
+            return self
+        registry = ToolRegistry()
+        for name in allowed_names:
+            tool = self.get(name)
+            if tool is not None:
+                registry.register(tool)
+        return registry

